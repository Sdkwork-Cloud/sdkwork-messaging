{
  "name": "@sdkwork/messaging-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "test": "vitest run",
    "test:migration": "node tests/messaging-migration-contract.test.mjs",
    "test:messaging-contracts": "vitest run packages/common/messaging/sdkwork-messaging-contracts/tests",
    "test:messaging-runtime": "vitest run packages/common/messaging/sdkwork-messaging-runtime/tests",
    "test:governance": "node scripts/messaging-governance.test.mjs",
    "typecheck": "tsc --noEmit",
    "sdk:materialize": "node sdks/materialize-messaging-v3-openapi-boundaries.mjs",
    "sdk:generate:app": "powershell -ExecutionPolicy Bypass -File sdks/sdkwork-messaging-app-sdk/bin/generate-sdk.ps1",
    "sdk:generate:backend": "powershell -ExecutionPolicy Bypass -File sdks/sdkwork-messaging-backend-sdk/bin/generate-sdk.ps1",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_messaging_legacy_baseline.sql --module-id messaging --owner messaging-platform --prefixes messaging_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rollup": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@sdkwork/sdk-common": "^1.0.2"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "sdkwork": {
    "owner": "sdkwork-messaging",
    "domain": "messaging",
    "apiAuthorities": [
      "sdkwork-messaging-app-api",
      "sdkwork-messaging-backend-api"
    ]
  }
}
